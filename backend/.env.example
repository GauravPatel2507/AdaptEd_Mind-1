# AdaptEd Mind Backend - Environment Variables Template
# Copy this to .env and fill in real values

PORT=3001
NODE_ENV=development

FIREBASE_PROJECT_ID=adaptedmind-1
FIREBASE_DATABASE_URL=https://adaptedmind-1-default-rtdb.asia-southeast1.firebasedatabase.app
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Groq API (for AI test generation)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=10

ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8082,http://localhost:19006
