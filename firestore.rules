// Firestore Security Rules for AdaptEd Mind
// Deploy via: firebase deploy --only firestore:rules
// Or paste into Firebase Console > Firestore > Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidString(field, minLen, maxLen) {
      return field is string && field.size() >= minLen && field.size() <= maxLen;
    }

    // ── Users ──────────────────────────────────────────────────────
    // Users can read any profile (for buddy matching), but only write their own
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Users cannot delete their accounts via client
    }

    // ── Quiz Results (Test Attempts) ───────────────────────────────
    // Users can read their own results, create new ones, but never modify/delete
    match /quizResults/{resultId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100;
      allow update, delete: if false; // Immutable records
    }

    // ── Progress ───────────────────────────────────────────────────
    // Users can read and write their own progress
    match /progress/{progressId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ── Tests ──────────────────────────────────────────────────────
    // Users can read their own tests, create new ones
    match /tests/{testId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ── Conversations & Messages ───────────────────────────────────
    // Only participants of a conversation can read/write
    match /conversations/{convId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow delete: if false;

      // Messages subcollection
      match /messages/{msgId} {
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
          && request.resource.data.senderId == request.auth.uid
          && isValidString(request.resource.data.text, 1, 2000);
        allow update, delete: if false; // Messages are immutable
      }
    }

    // ── Partner Requests ───────────────────────────────────────────
    match /partnerRequests/{requestId} {
      allow read: if isAuthenticated()
        && (resource.data.fromUserId == request.auth.uid
         || resource.data.toUserId == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.toUserId == request.auth.uid; // Only recipient can respond
      allow delete: if false;
    }

    // ── Study Buddies ──────────────────────────────────────────────
    match /studyBuddies/{buddyId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.users;
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.users;
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.users;
      allow delete: if false;
    }

    // ── Questions Bank (future) ────────────────────────────────────
    // Read-only for authenticated users; writes only via Admin SDK (backend)
    match /questions_bank/{questionId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin-only via backend
    }

    // ── Learning Profiles (future) ─────────────────────────────────
    match /learning_profiles/{profileId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow write: if false; // Updated only via backend
    }

    // ── Default: Deny everything else ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
